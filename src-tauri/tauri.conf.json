{
  "$schema": "https://raw.githubusercontent.com/niccokunzmann/tauri/refs/heads/dev/crates/tauri-cli/config.schema.json",
  "productName": "Super Terminal",
  "version": "../package.json",
  "identifier": "com.super-terminal.desktop",
  "build": {
    "frontendDist": "../crates/tauri-plugin-sessions/ui/dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev --prefix crates/tauri-plugin-sessions/ui -- --port 1421",
    "beforeBuildCommand": "npm run build && npm install --prefix crates/tauri-plugin-sessions/ui && npm run build --prefix crates/tauri-plugin-sessions/ui"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws: wss: http: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
